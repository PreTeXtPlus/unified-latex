{
    "name": "@unified-latex/unified-latex-cli",
    "version": "1.8.3",
    "description": "Command line interface to common unified-latex options",
    "main": "index.js",
    "type": "module",
    "bin": {
        "unified-latex": "./unified-latex-cli.mjs"
    },
    "dependencies": {
        "@types/hast": "^2.3.9",
        "@unified-latex/unified-latex-lint": "^1.8.3",
        "@unified-latex/unified-latex-to-hast": "^1.8.3",
        "@unified-latex/unified-latex-to-mdast": "^1.8.3",
        "@unified-latex/unified-latex-to-pretext": "^1.8.3",
        "@unified-latex/unified-latex-types": "^1.8.0",
        "@unified-latex/unified-latex-util-arguments": "^1.8.3",
        "@unified-latex/unified-latex-util-macros": "^1.8.3",
        "@unified-latex/unified-latex-util-packages": "^1.8.3",
        "@unified-latex/unified-latex-util-parse": "^1.8.3",
        "@unified-latex/unified-latex-util-print-raw": "^1.8.0",
        "@unified-latex/unified-latex-util-to-string": "^1.8.3",
        "camelcase": "^7.0.1",
        "chalk": "^5.2.0",
        "chokidar": "^3.5.3",
        "fault": "^2.0.1",
        "hastscript": "^7.2.0",
        "json5": "^2.2.3",
        "minimist": "^1.2.7",
        "prettier": "^2.8.8",
        "rehype-stringify": "^9.0.4",
        "remark-stringify": "^10.0.3",
        "text-table": "^0.2.0",
        "unified": "^10.1.2",
        "unified-engine": "^10.1.0"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/siefkenj/unified-latex.git"
    },
    "keywords": [
        "pegjs",
        "latex",
        "parser",
        "prettier",
        "unified-latex",
        "unified"
    ],
    "author": "Jason Siefken",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/siefkenj/unified-latex/issues"
    },
    "homepage": "https://github.com/siefkenj/unified-latex#readme",
    "exports": {
        ".": {
            "import": "./index.js",
            "require": "./index.cjs",
            "types": "./index.d.ts"
        },
        "./*js": "./*js",
        "./*": {
            "import": "./*/index.js",
            "require": "./*/index.cjs",
            "types": "./*/index.d.ts"
        },
        "./*/index": {
            "import": "./*/index.js",
            "require": "./*/index.cjs"
        }
    },
    "files": [
        "**/*ts",
        "**/*js",
        "**/*.map",
        "**/*.json"
    ]
}