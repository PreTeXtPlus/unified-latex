{
    "name": "@unified-latex/unified-latex-to-mdast",
    "version": "1.8.3",
    "description": "Convert a unified-latex AST to a MDAST AST (for Markdown conversion)",
    "main": "index.js",
    "type": "module",
    "dependencies": {
        "@types/mdast": "^4.0.1",
        "@unified-latex/unified-latex": "^1.8.3",
        "@unified-latex/unified-latex-to-hast": "^1.8.3",
        "@unified-latex/unified-latex-types": "^1.8.0",
        "hast": "^1.0.0",
        "hast-util-to-string": "^3.0.0",
        "rehype-remark": "^10.0.0",
        "remark-stringify": "^10.0.3",
        "unified": "^10.1.2"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/siefkenj/unified-latex.git"
    },
    "keywords": [
        "pegjs",
        "latex",
        "parser",
        "prettier",
        "unified-latex",
        "unified"
    ],
    "author": "Jason Siefken",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/siefkenj/unified-latex/issues"
    },
    "homepage": "https://github.com/siefkenj/unified-latex#readme",
    "exports": {
        ".": {
            "import": "./index.js",
            "require": "./index.cjs",
            "types": "./index.d.ts"
        },
        "./*js": "./*js",
        "./*": {
            "import": "./*/index.js",
            "require": "./*/index.cjs",
            "types": "./*/index.d.ts"
        },
        "./*/index": {
            "import": "./*/index.js",
            "require": "./*/index.cjs"
        }
    },
    "files": [
        "**/*ts",
        "**/*js",
        "**/*.map",
        "**/*.json"
    ]
}